// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Enum for queue entry status tracking
enum QueueEntryStatus {
  WAITING 
  CALLED
  SERVED
  CANCELLED
  NO_SHOW
}

// Host model - Authenticated service providers who create and manage queues
model Host {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  businessName String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  queues Queue[]

  @@map("hosts")
}

model Queue {
  id                 String    @id @default(uuid())
  qrCode             String    @unique
  name               String
  description        String?
  isActive           Boolean   @default(true)
  maxSize            Int?
  averageServiceTime Float       @default(5)
  requireNames       Boolean?  @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  hostId  String
  host    Host           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  entries QueueEntry[]

  @@index([hostId])
  @@index([qrCode])
  @@map("queues")
}

model QueueEntry {
  id                String           @id @default(uuid())
  queueId           String
  customerName      String?
  status            QueueEntryStatus @default(WAITING)
  displayNumber     String
  joinedAt          DateTime         @default(now())
  calledAt          DateTime?
  servedAt          DateTime?
  expiresAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  queue             Queue             @relation(fields: [queueId], references: [id], onDelete: Cascade)
  pushSubscription PushSubscription?

  @@index([queueId, status, joinedAt])
  @@map("queue_entries")
}

model PushSubscription {
  id        String   @id @default(uuid())
  entryId   String   @unique
  fcmToken  String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entry QueueEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([fcmToken])
  @@map("push_subscriptions")
}
